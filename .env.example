# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SLACK_WEBHOOK_URL: The webhook URL for your Slack channel notifications.
SLACK_WEBHOOK_URL=

# SMTP Configuration for Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ict.team@pceastandrews.org
SMTP_PASS=

# Google Sheets Configuration (for Fiscal Isolation & secondary database persistence)
# Set either the complete JSON service account key (base64 encoded or raw string)
GOOGLE_SERVICE_ACCOUNT_KEY=
# Or provide the individual client email and private key credentials explicitly:
GOOGLE_CLIENT_EMAIL=ict.team@pceastandrews.org
GOOGLE_PRIVATE_KEY=

# Supabase Database Migration configuration
# Set USE_SUPABASE to 'true' to activate Supabase (PostgreSQL), otherwise falls back to Firebase Firestore
VITE_USE_SUPABASE=false
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase direct PostgreSQL connection pooler URL or direct URL (e.g. postgresql://postgres.xxxx:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require)
DATABASE_URL=

# Firebase Auth Configuration (for Supabase Third-Party Auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=fintech-requisitions
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VPS Local Storage Configuration (for Requisition Uploads)
# Files are stored locally in the './uploads' directory of the VPS file system and served via Express on port 3000.
# Ensure that the 'uploads' directory has write permissions on your VPS.
VPS_IP=178.104.122.211

